# ================================================
# Variables de entorno requeridas para producción
# Copie este archivo como .env y rellene los valores
# ================================================

# URL de conexión a PostgreSQL
# En Render, esta variable se genera automáticamente desde el Blueprint
DATABASE_URL=postgresql://usuario:contraseña@host:5432/gleyforgym

# Clave secreta para firmar JWT (DEBE ser larga y aleatoria en producción)
SECRET_KEY=cambia_esto_por_una_clave_segura_de_64_caracteres_o_mas

# Tiempo de expiración del token de acceso en minutos (1440 = 24 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URL del frontend (para CORS)
# En Render: https://gleyforgym-ingenieriaweb-frontend.onrender.com
FRONTEND_URL=http://localhost:4200
